# App
APP_NAME=Financial News Research API
APP_ENV=development
DEBUG=true
LOG_TO_FILE=true
LOG_DIR=logs
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Security (JWT-ready)
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database (async SQLAlchemy + asyncpg)
DATABASE_URL=postgresql+asyncpg://finresearch:finresearch_dev_local@localhost:5433/finresearch

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# External APIs
FINNHUB_API_KEY=your_finnhub_key
NEWSAPI_KEY=your_newsapi_key
POLYGON_API_KEY=your_polygon_key
ANTHROPIC_API_KEY=your_anthropic_key
# Optional: model id from https://platform.claude.com/docs/en/api/models (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6
# Optional: only if you use a proxy or non-default API host
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Multi-LLM Deliberation (DIL)
DIL_ENABLED=true
# false = run in API process (uvicorn only). true = celery-worker (docker compose).
DIL_USE_CELERY=false
# Comma-separated models to skip (e.g. gemini when free-tier quota is exhausted)
DIL_EXCLUDE_MODELS=gemini
DIL_MIN_MODELS=2
DIL_MAX_DEBATE_ROUNDS=2
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Comma-separated desk keys to run (empty = all 13 registered desks).
DIL_ACTIVE_DESKS=
# Per-desk provider fallbacks: desk_key=prov1,prov2;desk_key2=...
# Groq desks: DeepSeek first when Groq daily/minute limits hit.
# Example: options_desk=deepseek,gpt,claude;event_risk_desk=deepseek,gpt,claude
DIL_DESK_FALLBACKS=options_desk=deepseek,gpt,claude;event_risk_desk=deepseek,gpt,claude
# Each core desk has a primary provider; fallbacks try in order on failure:
# gpt=Macro, claude=Fundamental, groq=Options, deepseek=Risk, gemini=Devil's Advocate
DIL_USE_ROLE_SPECIALIZATION=true
# Hybrid architecture: desk debate off by default; council handles decisions.
DIL_DESK_DEBATE_ENABLED=false
DIL_COUNCIL_ENABLED=true
DIL_COUNCIL_MIN_MEMBERS=3
DIL_COUNCIL_TRIGGERS=reverse_bwb
# Per-council-role fallbacks: portfolio_manager=claude,gemini;risk_manager=...
# contrarian_investor primary is Groq — DeepSeek first on quota failures.
DIL_COUNCIL_FALLBACKS=contrarian_investor=deepseek,gpt,claude

# DIL Production Resilience (concurrency, 429 retry, health, circuit breakers)
# Master kill-switch — set DIL_RESILIENCE_ENABLED=false to restore pre-resilience behavior exactly.
DIL_RESILIENCE_ENABLED=true
DIL_MAX_CONCURRENT_LLM_REQUESTS=5
DIL_429_MAX_RETRIES=1
DIL_429_MAX_WAIT_S=60
DIL_PROVIDER_COOLDOWN_S=300
DIL_HEALTH_DEGRADED_429_THRESHOLD=3
DIL_HEALTH_UNHEALTHY_FAILURE_THRESHOLD=5
DIL_CB_OPEN_DURATION_S=300
DIL_CB_PROBE_INTERVAL_S=30
# Full provider chains (first = primary): role=prov1,prov2;role2=...
# Recommended anti-stampede routing (opt-in — uncomment to enable):
# DIL_DESK_ROUTING=macro_desk=claude,gemini,gpt;options_desk=gpt,deepseek,claude;risk_desk=claude,deepseek,gpt;quant_desk=deepseek,gpt,claude
DIL_DESK_ROUTING=
DIL_ASSESSMENT_ROUTING=
# DIL_COUNCIL_ROUTING=portfolio_manager=gpt,claude,deepseek;contrarian_investor=groq,deepseek,gpt
DIL_COUNCIL_ROUTING=
# Quorum aliases (optional — override DIL_*_MIN_MEMBERS)
# ASSESSMENT_MIN_VALID_MEMBERS=2
# COUNCIL_MIN_VALID_MEMBERS=3
# DIL operational health: GET /api/v1/dil/health

# Reverse BWB Assessment Team
DIL_ASSESSMENT_ENABLED=true
DIL_ASSESSMENT_MIN_MEMBERS=2
DIL_ASSESSMENT_FALLBACKS=

# Options Intelligence (PR-A1 deterministic + PR-A2 live IV)
OPTIONS_ENABLED=true
OPTIONS_DEFAULT_HORIZON_DAYS=3
# Set to true to pull at-the-money IV from a live options chain. Falls back
# to realized vol silently on any provider failure.
OPTIONS_USE_LIVE_IV=false
# polygon | tradier
OPTIONS_CHAIN_PROVIDER=polygon
# Use a dedicated key if your Polygon plan separates equities from options;
# otherwise leave blank and POLYGON_API_KEY is reused.
POLYGON_OPTIONS_API_KEY=
TRADIER_API_KEY=
TRADIER_BASE_URL=https://api.tradier.com/v1

# Evidence relevance filter (PR-B) — drops Cava/Workday-style noise from
# single-ticker reports. Macro headlines stay in the narrative by default.
RELEVANCE_FILTER_ENABLED=true
INCLUDE_MACRO_IN_NARRATIVE=true

# Historical analogs (PR-C) — semantic Qdrant matches and pattern detectors
# (earnings_beat_sell_off, sector_rotation) on top of exact event-type SQL.
ANALOG_SEMANTIC_ENABLED=true
ANALOG_PATTERN_ENABLED=true

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=article_embeddings

# Models
EMBED_MODEL=all-MiniLM-L6-v2
FINBERT_MODEL=ProsusAI/finbert

# Rate limits (per minute, IP)
# Run All sequentially fires up to 12 /research calls per dashboard load,
# so the per-IP budget is roomier than the legacy single-ticker workbench.
RATE_LIMIT_RESEARCH=30/minute
RATE_LIMIT_DEFAULT=120/minute
# Slim watchlist projection — bursty when the grid loads + each card invalidates
# after its deliberation completes, so the budget is intentionally larger.
RATE_LIMIT_SUMMARIES=600/minute

# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=finresearch-api

# Reverse BWB Intelligence Dashboard
# Auto-runs the full 12-ticker watchlist on server startup (sequential). Leave
# false in dev so restarts don't burn LLM budget; flip to true in prod.
WATCHLIST_AUTO_RUN_ON_STARTUP=false
WATCHLIST_RUN_DAYS=7
REVERSE_BWB_SUMMARY_ENABLED=true
REVERSE_BWB_SUMMARY_MODEL=claude-sonnet-4-6
REVERSE_BWB_SUMMARY_MAX_TOKENS=1500

# IBKR Live Market Data
# Master kill-switch. When false, the dashboard serves only the frozen
# analysis snapshot (existing behavior). Flip to true once IBKR Gateway is
# running on the configured host/port. Live data and analysis remain in
# separate tables — re-running analysis never overwrites a live price tick.
IBKR_ENABLED=false
IBKR_HOST=127.0.0.1
# 4001=paper, 4002=live for IB Gateway; 7497/7496 for TWS.
IBKR_PORT=4001
IBKR_CLIENT_ID=17
IBKR_PAPER=true
IBKR_CONNECT_TIMEOUT_S=10
# Worker cadence
MARKET_DATA_PRICE_FLUSH_MS=1000
MARKET_DATA_OPP_INTERVAL_S=45
MARKET_DATA_STALE_THRESHOLD_S=10
# Legacy DTE window — kept for back-compat with the original top-2 generator.
OPP_TARGET_DTE_MIN=7
OPP_TARGET_DTE_MAX=21
# Legacy cap; now only controls how many top-ranked rows per side get
# refined via IBKR WhatIf. All other rows use the deterministic formula.
OPP_RANK_TOP_N_PER_SIDE=2

# Reverse BWB Trading Workstation — full opportunity enumeration
# DTE window: Monday entries targeting Wed/Fri expiries → 0-5 days is the default.
# Set OPP_DTE_MAX=14 to include next-week expirations.
OPP_DTE_MIN=0
OPP_DTE_MAX=5
# Wing-width search bounds in strike-step units (1..20).
OPP_WING_MIN_STRIKES=1
OPP_WING_MAX_STRIKES=20
# Minimum open interest per leg before a candidate is considered.
OPP_MIN_LEG_OI=10
# Hard cap on distinct option legs sent to IBKR per cycle (nearest-ATM priority).
OPP_MAX_DISTINCT_LEGS=300
# Only use strikes within ±N% of the underlying price (reduces candidate explosion).
OPP_MAX_STRIKE_DIST_PCT=10.0
# Discard combos whose net credit is smaller than this (dollars per lot).
# 0 = allow all credits through; set to 20 for "≥ $20 credit only".
OPP_MIN_CREDIT_USD=20.0
# WhatIf budget — refine only top-N rows per side per ticker; rest use the
# deterministic margin formula. Keeps IBKR pacing budget safe (~10-20/min).
OPP_WHATIF_TOP_N=25
OPP_WHATIF_MAX_PER_MIN=12
# Event-driven recalc thresholds. Recalc fires when ANY is true.
OPP_RECALC_PRICE_PCT=0.25
OPP_RECALC_IV_PCT=3.0
OPP_RECALC_MAX_AGE_S=900
# WebSocket tick fanout debounce (ms).
WS_TICK_BATCH_MS=250

# Quote cache — decouples DB writes from the WebSocket hot path.
# DB flush: how often the in-memory quote cache is persisted to PostgreSQL.
MARKET_DATA_DB_FLUSH_S=5
# Redis TTL for quote:{TICKER} keys (seconds). Must be > MARKET_DATA_DB_FLUSH_S.
QUOTE_CACHE_TTL_S=30

# Redis Pub/Sub fanout — enable for multi-process / load-balanced deployments.
# When true, ticks are published to Redis channels so ALL API instances fan out
# to their own WebSocket clients. Leave false for single-process dev.
REDIS_PUBSUB_ENABLED=false
